# Copy this file to .env, set SECRET_KEY, and you're done — everything
# else is optional. NEVER commit .env to version control.

# ── Required ──────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# ── Basics (optional) ─────────────────────────────────────────────
# Host port the app is exposed on (default: 8000)
APP_PORT=8000

# SQLite database file. Default works for both Docker (./data is mounted
# into the container) and bare-metal runs from the project directory.
#DB_PATH=data/books.db

# Default library title when none has been set in the setup wizard or the
# Settings page (those are stored in the database and win over this).
#SITE_NAME=BookNexus

# ── TLS ───────────────────────────────────────────────────────────
# HTTPS is ON by default: a self-signed certificate is generated
# automatically on first boot (browsers warn once — expected), because the
# camera barcode scanner requires a secure origin. Manage the certificate
# from the in-app Settings page: upload your own, regenerate, or disable.
#
# Advanced alternative: point directly at cert files (the Settings page
# then shows them as environment-managed). Put them in ./certs/ and use
# relative paths; key readable by uid/gid 10001 in Docker.
#TLS_CERT=certs/fullchain.pem
#TLS_KEY=certs/privkey.pem

# Set to "true" only if the app is behind a TLS-terminating proxy
# (disables the built-in HTTPS; the proxy handles certificates)
HTTPS=false

# Set to "true" only when behind a reverse proxy that sets
# X-Forwarded-For/X-Forwarded-Proto, so the login rate limiter sees real
# client IPs instead of the proxy's
PROXY_FIX=false

# ── Admin login (optional) ────────────────────────────────────────
# Leave unset: the app shows a first-run setup wizard at /setup where you
# create the admin account and name your library. Complete it right after
# deploying. A password set through the wizard or the in-app Settings page
# is stored (hashed) in the database and takes precedence over these.
#ADMIN_USERNAME=admin
# Hash generated with:
#   python3 -c "from werkzeug.security import generate_password_hash; import getpass; print(generate_password_hash(getpass.getpass()))"
# Keep the single quotes — the hash contains '$' characters.
#ADMIN_PASSWORD_HASH='scrypt:32768:8:1$...$...'
#ADMIN_PASSWORD=plaintext-fallback-not-recommended

# ── Backups (optional) ────────────────────────────────────────────
# backup_db.sh snapshots the database into ./backups/ (14-day retention).
# Optional off-host copy: rsync-over-ssh destination (key auth; remote
# accumulates full history).
#BACKUP_REMOTE=user@host:backups/booknexus/
#BACKUP_REMOTE_KEY=/home/youruser/.ssh/id_ed25519

# Optional dataset publish: after each backup run the books table is
# exported (CSV + seed SQL, no synopses) and pushed to a public data repo
# when changed.
#DATA_REPO_SSH=git@github.com:youruser/your-data-repo.git
#DATA_REPO_KEY=/home/youruser/.ssh/deploy_key
