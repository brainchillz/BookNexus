# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.

# ── Docker-compose ────────────────────────────────────────────────
# Root password for the MySQL container (only used by Docker)
MYSQL_ROOT_PASSWORD=change-this-root-password

# Host port the app is exposed on (default: 8000)
APP_PORT=8000

# ── Database ──────────────────────────────────────────────────────
# For Docker: DB_HOST is always "db" (set automatically by docker-compose)
# For manual installs: set DB_HOST=localhost here and point the app at your MySQL
DB_HOST=localhost
DB_USER=books_user
DB_PASSWORD=change-this-db-password
DB_NAME=books

# ── Flask ─────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# ── TLS ───────────────────────────────────────────────────────────
# Paths to a certificate (full chain) and private key. When BOTH are set,
# gunicorn serves HTTPS directly and the Secure cookie flag + HSTS header
# turn on automatically. Leave unset to serve plain HTTP.
# Put the files in ./certs/ and use relative paths — they resolve both on
# bare metal (cwd = project dir) and in Docker (./certs is mounted at
# /app/certs, cwd = /app). Key must be readable by uid/gid 10001 in Docker.
#TLS_CERT=certs/fullchain.pem
#TLS_KEY=certs/privkey.pem

# Set to "true" only if the app is instead behind a TLS-terminating proxy
# (enables the Secure cookie flag + HSTS without serving TLS itself)
HTTPS=false

# ── Backups ───────────────────────────────────────────────────────
# backup_db.sh always dumps the Docker DB when the stack is running.
# Set to "true" on hosts that ALSO run a bare-metal MySQL on the same host
# so the script dumps that one too.
BACKUP_BAREMETAL=false

# Optional off-host copy: rsync-over-ssh destination synced after each
# backup run (key auth; remote accumulates full history).
#BACKUP_REMOTE=user@host:backups/booklibrary/
#BACKUP_REMOTE_KEY=/home/youruser/.ssh/id_ed25519

# Optional dataset publish (production only): after each backup run the
# books table is exported (CSV + seed SQL, no synopses) and pushed to the
# public data repo when changed. Fresh installs seed from that repo.
#DATA_REPO_SSH=git@github.com:youruser/your-data-repo.git
#DATA_REPO_KEY=/home/youruser/.ssh/github_bookdata

# Set to "true" only when behind a reverse proxy that sets
# X-Forwarded-For/X-Forwarded-Proto, so the login rate limiter sees real
# client IPs instead of the proxy's
PROXY_FIX=false

# ── Admin login (OPTIONAL) ────────────────────────────────────────
# Leave this whole section unset for a fresh install: the app shows a
# first-run setup wizard at /setup where you create the admin account and
# name your library. Complete it right after deploying.
#
# The variables below are a fallback for installs that predate the wizard,
# or if you prefer env-managed credentials. A password set through the
# wizard or the in-app Settings page is stored (hashed) in the database
# and takes precedence over these.
#ADMIN_USERNAME=admin
# Hash generated with:
#   python3 -c "from werkzeug.security import generate_password_hash; import getpass; print(generate_password_hash(getpass.getpass()))"
# IMPORTANT: keep the single quotes — the hash contains '$' characters that
# docker-compose would otherwise try to interpolate.
#ADMIN_PASSWORD_HASH='scrypt:32768:8:1$...$...'
#ADMIN_PASSWORD=plaintext-fallback-not-recommended

# ── Branding (optional) ───────────────────────────────────────────
# Default library title when none has been set in the setup wizard or the
# Settings page (those are stored in the database and win over this).
#SITE_NAME=Cindy's Book Collection

# ── Seed data (optional) ──────────────────────────────────────────
# URL of a books.sql to fetch before starting (deploy.sh). Only imported
# when the MySQL volume is brand new. Leave unset to install with an
# empty library.
#SEED_DATA_URL=https://raw.githubusercontent.com/youruser/your-data-repo/main/books.sql
